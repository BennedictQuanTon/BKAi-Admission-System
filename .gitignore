# ============================================================
# BKAi — .gitignore
# ============================================================

# ===== OS =====
.DS_Store
**/.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ===== IDE / Editor =====
.vscode/
.cursor/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
.eggs/
build/

# ===== Virtual Environment =====
.venv/
venv/
env/
ENV/
.python-version

# ===== Environment Variables (SENSITIVE) =====
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example
dashboard/.env
dashboard/.env.*
!dashboard/.env.example

# ===== Knowledge base (SENSITIVE — do NOT commit raw admissions data) =====
# Keep folder layout via .gitkeep; ignore all real content.
backend/data/raw/*
!backend/data/raw/.gitkeep
backend/data/csv/*
!backend/data/csv/.gitkeep
backend/data/pdf/*
!backend/data/pdf/.gitkeep
backend/data/docx/*
!backend/data/docx/.gitkeep
backend/data/processed/*
!backend/data/processed/.gitkeep

# ===== Binary / Pickle artifacts (generated, large) =====
*.pkl
*.pickle
*.bin
*.mmap

# ===== Vector DB / Cache (generated runtime data, not for VCS) =====
backend/.qdrant/
backend/memory/vector_db/
backend/memory/redis_data/
backend/temp_audio/

# ===== Node.js =====
node_modules/
.next/
dist/
.cache/
*.tsbuildinfo

# ===== Logs / local eval runs =====
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
backend/evaluation/demo_run.log

# ===== Docker overrides (local-only) =====
docker-compose.override.yml
docker-compose.local.yml

# ===== Misc =====
*.bak
*.tmp
coverage/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
test.mp3

# ===== Local reference assets (not part of product) =====
Voice_Agent_Images/
