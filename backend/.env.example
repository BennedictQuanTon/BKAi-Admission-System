# ===== Google Gemini API =====
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL_PRIMARY=gemini-3.1-flash-lite
GEMINI_MODEL_FAST=gemini-3.1-flash-lite
GEMINI_RPM_LIMIT_LITE=10
GEMINI_RPM_LIMIT_FLASH=10

# ===== Redis Configuration =====
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_DB=1
REDIS_STATS_DB=2

# ===== ChromaDB Configuration =====
CHROMA_PERSIST_DIR=./memory/vector_db
CHROMA_COLLECTION_NAME=bkai_knowledge


# ===== Embedding Configuration =====
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ===== API Configuration =====
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ===== Search Configuration =====
HYBRID_SEARCH_ALPHA=0.7
RERANK_TOP_K=8
RETRIEVAL_TOP_K=20

# ===== Cache Configuration =====
SEMANTIC_CACHE_THRESHOLD=0.92
CACHE_TTL_UNRATED=604800
CACHE_TTL_LIKED=2592000

# ===== Security & Rate Limiting =====
MAX_CONCURRENT_USERS=8
RATE_LIMIT_PER_MINUTE=15
MAX_INPUT_LENGTH=500

# ===== Guardrails =====
GUARDRAILS_ENABLED=true
GUARDRAILS_ALLOWED_SCOPE=HCMUT_ADMISSIONS

# ===== Branding =====
APP_NAME=BkAI
