# ===== Ollama Configuration =====
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_PRIMARY=qwen2.5:7b
OLLAMA_MODEL_FAST=llama3.2

# ===== Redis Configuration =====
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_DB=1
REDIS_STATS_DB=2

# ===== ChromaDB Configuration =====
CHROMA_PERSIST_DIR=./memory/vector_db
CHROMA_COLLECTION_NAME=bkai_knowledge

# ===== Embedding Configuration =====
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ===== API Configuration =====
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ===== Search Configuration =====
HYBRID_SEARCH_ALPHA=0.7
RERANK_TOP_K=5
RETRIEVAL_TOP_K=20

# ===== Cache Configuration =====
SEMANTIC_CACHE_THRESHOLD=0.92
CACHE_TTL_UNRATED=604800
CACHE_TTL_LIKED=2592000

# ===== Security =====
MAX_CONCURRENT_USERS=15
RATE_LIMIT_PER_MINUTE=30
MAX_INPUT_LENGTH=500

# ===== Web Search =====
WEB_SEARCH_DOMAIN=hcmut.edu.vn
